{
  "name": "site2rag",
  "version": "1.0.0",
  "description": "Website mirror + RAG-ready MD export service",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ bin/ tests/",
    "postinstall": "node bin/setup.js",
    "build:css": "echo '@import \"tailwindcss\";' > public/tw-input.css && node_modules/.bin/tailwindcss -i public/tw-input.css -o public/tailwind.css --minify && rm public/tw-input.css",
    "deploy:ui": "npm run build:css && npx wrangler pages deploy public/ --project-name=site2rag-report"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^12.0.0",
    "cheerio": "^1.0.0",
    "fast-xml-parser": "^4.3.6",
    "js-yaml": "^4.1.0",
    "jsdom": "^24.1.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.4.168",
    "tesseract.js": "^5.1.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "tailwindcss": "^4.2.4",
    "vitest": "^2.1.8"
  }
}
