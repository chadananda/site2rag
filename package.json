{
  "name": "site2rag",
  "version": "1.0.0",
  "description": "Website mirror + RAG-ready MD export service",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ bin/ tests/",
    "postinstall": "node bin/setup.js",
    "build:css": "echo '@import \"tailwindcss\";' > public/tw-input.css && node_modules/.bin/tailwindcss -i public/tw-input.css -o public/tailwind.css --minify && rm public/tw-input.css",
    "deploy:ui": "node scripts/deploy-ui.js",
    "deploy:backend": "git push origin main && ssh tower-nas 'cd /tank/site2rag/app && git pull && pm2 reload site2rag && pm2 reload pdf-report-server'",
    "deploy:all": "npm run deploy:ui && npm run deploy:backend",
    "restart:spider": "ssh tower-nas 'pm2 reload site2rag'",
    "restart:api": "ssh tower-nas 'pm2 reload pdf-report-server'",
    "restart:worker": "ssh tower-nas 'pm2 reload pdf-upgrade-worker'",
    "restart:all": "ssh tower-nas 'pm2 reload all'",
    "logs:spider": "ssh tower-nas 'tail -100f /tank/site2rag/logs/site2rag.out.log'",
    "logs:spider:err": "ssh tower-nas 'tail -100f /tank/site2rag/logs/site2rag.err.log'",
    "logs:api": "ssh tower-nas 'tail -100f /tank/site2rag/logs/report-server.out.log'",
    "logs:api:err": "ssh tower-nas 'tail -100f /tank/site2rag/logs/report-server.err.log'",
    "status": "ssh tower-nas 'pm2 status'",
    "ssh": "ssh tower-nas"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^12.0.0",
    "cheerio": "^1.0.0",
    "fast-xml-parser": "^4.3.6",
    "js-yaml": "^4.1.0",
    "jsdom": "^24.1.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.4.168",
    "tesseract.js": "^5.1.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "@napi-rs/canvas": "^0.1.100",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "tailwindcss": "^4.2.4",
    "vitest": "^2.1.8"
  }
}
